# Database Configuration
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE_NAME=ORCLPDB1
DB_USERNAME=analytics_user
DB_PASSWORD=your_password_here

# Connection Pool Settings
DB_POOL_MAX=50
DB_POOL_MIN=10

# Application Settings
API_PORT=8082
THREADS=20

# New Relic Configuration
# This license key is what actually authenticates the .NET agent (it overrides
# newrelic.config). run.sh uses it to attach the CoreCLR profiler at launch.
NEW_RELIC_LICENSE_KEY=your_license_key_here
NEW_RELIC_APP_NAME=App3-Analytics-LoadGenerator-DotNet
