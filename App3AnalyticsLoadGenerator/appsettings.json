{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "OracleDb": "User Id=${DB_USERNAME};Password=${DB_PASSWORD};Data Source=${DB_HOST}:${DB_PORT}/${DB_SERVICE_NAME}"
  },
  "Database": {
    "MaxPoolSize": "${DB_POOL_MAX}",
    "MinPoolSize": "${DB_POOL_MIN}",
    "ConnectionTimeout": 30,
    "CommandTimeout": 180
  },
  "LoadGenerator": {
    "Threads": "${THREADS}",
    "ApiBaseUrl": "http://localhost:${API_PORT}"
  }
}
